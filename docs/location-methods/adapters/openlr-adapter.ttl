@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <https://w3id.org/itsdata/location/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

:OpenLRAdapter
    a owl:Ontology ;
    dcterms:title "OpenLR adapter (ITS location referencing scaffold)"@en ;
    skos:definition "Adapter stub for aligning OpenLR concepts to methodology-first location referencing modules. This file is a scaffold; existing OpenLR ontology files are unchanged."@en ;
    dcterms:creator "Kenneth Vaughn" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    its-core:draft "true" ;
    owl:imports :LocationCorePattern ;
    owl:imports :LinearReferencingPattern ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <https://w3id.org/itsdata/location/v1/OpenLRAdapter/r0.1> ;
    vann:preferredNamespacePrefix "its-location" ;
    vann:preferredNamespaceUri "https://w3id.org/itsdata/location/v1/" .

### Placeholder alignment points (to be filled as mappings are defined)

:OpenLRLocationReference
    a owl:Class ;
    rdfs:subClassOf :Location ;
    skos:definition "Placeholder class for OpenLR location references (to be aligned with existing OpenLR pattern)."@en .

