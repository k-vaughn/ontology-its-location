@prefix : <https://w3id.org/itsdata/location/v1/> .
@prefix cms2: <> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:OpenLRPattern
    dcterms:created               "Draft" ;
    dcterms:creator               "Kenneth Vaughn" ;
    dcterms:license               "http://creativecommons.org/licenses/by/4.0/" ;
    dcterms:modified              "2026-04-07"^^xsd:date ;
    dcterms:source                "https://docs.datex2.eu/_static/data/v3.7/umlmodel/html/index.htm"@en ;
    dcterms:source                "http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti" ;
    dcterms:title                 "OpenLR concepts of the Location Ontology for ITS" ;
    its-core:draft                "true" ;
    owl:imports                   :Core ;
    owl:priorVersion              <https://w3id.org/itsdata/location/v1/OpenLRPattern/r0.2> ;
    owl:versionIRI                <https://w3id.org/itsdata/location/v1/OpenLRPattern/r0.3> ;
    owl:versionInfo               "0.0.3" ;
    rdf:type                      owl:Ontology ;
    skos:definition               "This ontology defines concepts related to OpenLR location within Intelligent Transportation Systems (ITS)." ;
    skos:definition               "This ontology was derived from the dtx_srti ontology, which was derived from the DATEX II v3.2 model; it has been updated to consider changes made up to DATEX II v3.7 and revised to support more generic representations, such as deriving classes from the City Data Model and other ontologies." ;
    vann:preferredNamespacePrefix "its-location" ;
    vann:preferredNamespaceUri    "https://w3id.org/itsdata/location/v1/" .

:hasOpenLRAreaLocationReference a owl:ObjectProperty

# Enumeration Classes and Individuals

:FunctionalRoadClassCode rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    rdfs:subClassOf cms2:Code ;
    skos:definition "Functional road class based on importance."@em ;
    skos:example "Main road, first-class road, second-class road"@en .

:FormOfWayCode rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    rdfs:subClassOf cms2:Code ;
    skos:definition "Physical road type."@em ;
    skos:example "motorway, multiple carriageway, single carriageway"@en .

:SideOfRoadCode rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    rdfs:subClassOf cms2:Code ;
    skos:definition "Side of the road for point locations."@em ;
    skos:example "Left, Right, Both"@en .

:OrientationCode rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    rdfs:subClassOf cms2:Code ;
    skos:definition "Orientation for point locations."@em ;
    skos:example "No orientation, With line direction, Against line direction, Both"@en .

:value rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:range xsd:integer ;
    skos:definition "Value of the enumeration."@en .

# Core Classes

:OpenLRThing rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    skos:definition "Grouping of OpenLR classes." .

:OpenLRObjectProperty rdf:type owl:ObjectProperty ;
    skos:definition "Grouping of OpenLR object properties." .

:OpenLRDataProperty rdf:type owl:DataProperty ;
    skos:definition "Grouping of OpenLR data properties." .

# :Coordinates replace with :PointCoordinates
:OpenLRLineAttributes rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    skos:definition "Attributes of a line: toad class, type of way, and bearing." .

:OpenLRLineAttributesShape sh:NodeShape ;
    sh:targetClass :OpenLRLineAttributes ;
    sh:property [ 
        sh:path :hasFRC ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :FunctionalRoadClassCode ;
    ] ;
    sh:property [
        sh:path :hasFOW ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :FormOfWayCode ;
    ] ;
    sh:property [
        sh:path :bearing ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:integer ;
    ] .

:hasFRC rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :OpenLRLineAttributes ;
    rdfs:range :FunctionalRoadClass .

:hasFOW rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :OpenLRLineAttributes ;
    rdfs:range :FormOfWay .

:bearing rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:domain :OpenLRLineAttributes ;
    rdfs:range xsd:integer ;
    skos:definition "Bearing value."@en .

:OpenLRPathAttributes rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    skos:definition "Attributes to next point: lowest FRC, distance."@en .
:OpenLRPathAttributesShape sh:NodeShape ;
    sh:targetClass :OpenLRPathAttributes ;
    sh:property [ 
        sh:path :hasLowestFRCToNext ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :FunctionalRoadClassCode ;
    ] ;
    sh:property [
        sh:path :distanceToNext ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:integer ;
    ] .

:hasLowestFRCToNext rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :OpenLRPathAttributes ;
    rdfs:range :FunctionalRoadClass .

:distanceToNext rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:domain :OpenLRPathAttributes ;
    rdfs:range xsd:integer ;
    skos:definition "Distance in meters to next point."@en .

:OpenLRLocationReferencePoint rdf:type owl:Class ;
    rdfs:subClassOf :OpenLRThing ;
    skos:definition "LRP with coordinates, line, and path attributes."@en .

:OpenLRLocationReferencePoint sh:NodeShape ;
    sh:targetClass :OpenLRLocationReferencePoint ;
    sh:property [
        sh:path :hasCoordinates ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :PointCoordinates ;
    ] ;
    sh:property [
        sh:path :hasLineAttributes ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :OpenLRLineAttributes ;
    ] ;
    sh:property [
        sh:path :hasPathAttributes ;
        sh:node its-sh:MaxOneShape ;
        sh:class :OpenLRPathAttributes ;
    ] .

:hasCoordinates rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :OpenLRLocationReferencePoint ;
    rdfs:range :PointCoordinates .

:hasLineAttributes rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :OpenLRLocationReferencePoint ;
    rdfs:range :OpenLRLineAttributes .

:hasPathAttributes rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :OpenLRLocationReferencePoint ;
    rdfs:range :OpenLRPathAttributes .

:LineLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Line location with LRPs and offsets." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasLRP ;
                      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                      owl:onClass :LocationReferencePoint
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :positiveOffset ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :negativeOffset ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] .

:hasLRP rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:domain :LineLocationReference ;
    rdfs:range :LocationReferencePoint ;
    skos:definition "Ordered list of LRPs." .

:positiveOffset rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:range xsd:integer ;
    skos:definition "Positive offset in meters." .

:negativeOffset rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:range xsd:integer ;
    skos:definition "Negative offset in meters." .

:ClosedLineLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LineLocationReference ;
    skos:definition "Closed line (polygon boundary) location." .

:GeoCoordinateLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Unbound point location." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasCoordinates ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Coordinates
                    ] .

:PointAlongLineLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Point along a line with offset." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasLRP ;
                      owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                      owl:onClass :LocationReferencePoint
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :positiveOffset ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasOrientation ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Orientation
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasSideOfRoad ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :SideOfRoad
                    ] .

:hasOrientation rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :Orientation .

:hasSideOfRoad rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :SideOfRoad .

:PoiWithAccessPointLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "POI with access point along line." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasLRP ;
                      owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                      owl:onClass :LocationReferencePoint
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :positiveOffset ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasPOICoordinates ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Coordinates
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasOrientation ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Orientation
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasSideOfRoad ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :SideOfRoad
                    ] .

:hasPOICoordinates rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :Coordinates .

:CircleLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Circle area location." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasCenter ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Coordinates
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :radius ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] .

:hasCenter rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :Coordinates .

:radius rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:range xsd:integer ;
    skos:definition "Radius in meters." .

:RectangleLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Rectangle area location." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasLowerLeft ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Coordinates
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasUpperRight ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Coordinates
                    ] .

:hasLowerLeft rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :Coordinates .

:hasUpperRight rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :Coordinates .

:GridLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :RectangleLocationReference ;
    skos:definition "Grid area location." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :numColumns ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :numRows ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] .

:numColumns rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:range xsd:integer .

:numRows rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OpenLRDataProperty ;
    rdfs:range xsd:integer .

:PolygonLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Polygon area location." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasCorner ;
                      owl:minQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
                      owl:onClass :Coordinates
                    ] .

:hasCorner rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    rdfs:range :Coordinates ;
    skos:definition "Ordered list of corners." .

:OpenLRAreaLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Area location reference using OpenLR line locations as boundaries." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasBoundaryLine ;
                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :LineLocationReference
                    ] .

:OpenLRLinear rdf:type owl:Class ;
    rdfs:subClassOf :LineLocationReference ;
    skos:definition "Line location reference using OpenLR." .

:hasOpenLRLinear rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    schema:domainIncludes :LinearLocation ;
    rdfs:range :OpenLRLinear ;
    skos:definition "Line location reference using OpenLR." .

:OpenLRPointLocationReference rdf:type owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "Point location reference using OpenLR." ;
    rdfs:subClassOf [ rdf:type owl:Restriction ;
                      owl:onProperty :hasLRP ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :LocationReferencePoint
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasOrientation ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :Orientation
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :hasSideOfRoad ;
                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onClass :SideOfRoad
                    ] .    

:hasOpenLRPointLocationReference rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :OpenLRObjectProperty ;
    schema:domainIncludes :PointLocation ;
    rdfs:range :OpenLRPointLocationReference ;
    skos:definition "Point location reference using OpenLR." .