@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <https://w3id.org/itsdata/location/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

:
    dcterms:created               "Draft" ;
    dcterms:creator               "Kenneth Vaughn" ;
    dcterms:license               "http://creativecommons.org/licenses/by/4.0/" ;
    dcterms:modified              "2026-04-07"^^xsd:date ;
    dcterms:source                "https://docs.datex2.eu/_static/data/v3.7/umlmodel/html/index.htm"@en ;
    dcterms:source                "http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti" ;
    dcterms:title                 "Ontology for ITS Location Referencing" ;
    its-core:draft                "true" ;
    owl:imports                   :AlertCLocationPattern ;
    owl:imports                   :LocationPattern ;
    owl:imports                   :OpenLRPattern ;
    owl:priorVersion              <https://w3id.org/itsdata/location/v1/r0.2> ;
    owl:versionIRI                <https://w3id.org/itsdata/location/v1/r0.3> ;
    owl:versionInfo               "0.0.3" ;
    rdf:type                      owl:Ontology ;
    skos:definition               "This ontology defines concepts related to locations and positioning within the ITS domain using concepts specified in ISO/IEC 5087-1 and ISO/IEC-5087-2." ;
    skos:note                     "This ontology was derived from the dtx_srti ontology, which was derived from the DATEX II v3.2 model; it has been updated to consider changes made up to DATEX II v3.7 and revised to support more generic representations, such as deriving classes from the City Data Model and other ontologies." ;
    vann:preferredNamespacePrefix "its-location" ;
    vann:preferredNamespaceUri    "https://w3id.org/itsdata/location/v1/" .

