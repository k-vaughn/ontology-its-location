// Diagram for Itinerary
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Feature [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Feature</TD></TR></TABLE>> URL="../Feature" margin=0]
	}
	Itinerary [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Itinerary</TD></TR></TABLE>> URL="../Itinerary" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		ItineraryRepresentation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ItineraryRepresentation</TD></TR></TABLE>> URL="../ItineraryRepresentation" margin=0]
	}
	Itinerary -> Feature [arrowhead=onormal style=solid]
	Itinerary -> Invis [style=invis]
	Invis -> ItineraryRepresentation [style=invis]
	ItineraryRepresentation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ItineraryRepresentation</TD></TR></TABLE>> URL="../ItineraryRepresentation" margin=0]
	Itinerary -> ItineraryRepresentation [label=hasPrimaryRepresentation arrowhead=normal style=solid]
	Itinerary -> ItineraryRepresentation [label=hasAlternativeRepresentation arrowhead=normal style=solid]
}
