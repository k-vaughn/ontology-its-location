// Diagram for PositionConfidenceEllipse
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		LocationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LocationThing</TD></TR></TABLE>> URL="../LocationThing" margin=0]
	}
	PositionConfidenceEllipse [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PositionConfidenceEllipse</TD></TR></TABLE>> URL="../PositionConfidenceEllipse" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		cdm1_Length [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Length</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Length" margin=0]
		"its-core_Bearing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Bearing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Bearing" margin=0]
		MeasurementErrorCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">MeasurementErrorCode</TD></TR></TABLE>> URL="../MeasurementErrorCode" margin=0]
	}
	PositionConfidenceEllipse -> LocationThing [arrowhead=onormal style=solid]
	PositionConfidenceEllipse -> Invis [style=invis]
	Invis -> cdm1_Length [style=invis]
	cdm1_Length -> "its-core_Bearing" [style=invis]
	"its-core_Bearing" -> MeasurementErrorCode [style=invis]
	cdm1_Length [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Length</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Length" margin=0]
	PositionConfidenceEllipse -> cdm1_Length [label=semiMajorAxisLength arrowhead=normal style=solid]
	PositionConfidenceEllipse -> cdm1_Length [label=semiMinorAxisLength arrowhead=normal style=solid]
	"its-core_Bearing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Bearing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Bearing" margin=0]
	PositionConfidenceEllipse -> "its-core_Bearing" [label=semiMajorAxisOrientation arrowhead=normal style=solid]
	MeasurementErrorCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">MeasurementErrorCode</TD></TR></TABLE>> URL="../MeasurementErrorCode" margin=0]
	PositionConfidenceEllipse -> MeasurementErrorCode [label=semiMajorAxisLengthErrorCode arrowhead=normal style=solid]
	PositionConfidenceEllipse -> MeasurementErrorCode [label=semiMinorAxisLengthErrorCode arrowhead=normal style=solid]
	PositionConfidenceEllipse -> MeasurementErrorCode [label=semiMajorAxisOrientationErrorCode arrowhead=normal style=solid]
}
