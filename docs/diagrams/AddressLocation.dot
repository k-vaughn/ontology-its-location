// Diagram for AddressLocation
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Location</TD></TR></TABLE>> URL="../Location" margin=0]
	}
	AddressLocation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">AddressLocation</TD></TR></TABLE>> URL="../AddressLocation" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		schema1_PostalAddress [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">schema1:PostalAddress</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/schema1/latest/PostalAddress" margin=0]
	}
	AddressLocation -> Location [arrowhead=onormal style=solid]
	AddressLocation -> Invis [style=invis]
	Invis -> schema1_PostalAddress [style=invis]
	schema1_PostalAddress [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">schema1:PostalAddress</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/schema1/latest/PostalAddress" margin=0]
	AddressLocation -> schema1_PostalAddress [label="hasPostalAddress
1" arrowhead=normal style=solid]
}
