// Diagram for DistanceAccuracy
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		LocationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LocationThing</TD></TR></TABLE>> URL="../LocationThing" margin=0]
	}
	DistanceAccuracy [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">DistanceAccuracy</TD></TR></TABLE>> URL="../DistanceAccuracy" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		cdm1_Length [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Length</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Length" margin=0]
		cdm1_Ratio [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Ratio</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Ratio" margin=0]
		MeasurementErrorCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">MeasurementErrorCode</TD></TR></TABLE>> URL="../MeasurementErrorCode" margin=0]
	}
	DistanceAccuracy -> LocationThing [arrowhead=onormal style=solid]
	DistanceAccuracy -> Invis [style=invis]
	Invis -> cdm1_Length [style=invis]
	cdm1_Length -> cdm1_Ratio [style=invis]
	cdm1_Ratio -> MeasurementErrorCode [style=invis]
	cdm1_Length [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Length</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Length" margin=0]
	DistanceAccuracy -> cdm1_Length [label=hasDistanceAccuracy arrowhead=normal style=solid]
	cdm1_Ratio [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Ratio</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Ratio" margin=0]
	DistanceAccuracy -> cdm1_Ratio [label=confidencePercentage arrowhead=normal style=solid]
	MeasurementErrorCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">MeasurementErrorCode</TD></TR></TABLE>> URL="../MeasurementErrorCode" margin=0]
	DistanceAccuracy -> MeasurementErrorCode [label=distanceAccuracyErrorCode arrowhead=normal style=solid]
}
