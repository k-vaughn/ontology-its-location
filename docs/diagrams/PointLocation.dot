// Diagram for PointLocation
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Location</TD></TR></TABLE>> URL="../Location" margin=0]
	}
	PointLocation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointLocation</TD></TR></TABLE>> URL="../PointLocation" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		"its-core_Bearing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Bearing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Bearing" margin=0]
		PointRepresentation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointRepresentation</TD></TR></TABLE>> URL="../PointRepresentation" margin=0]
	}
	PointLocation -> Location [arrowhead=onormal style=solid]
	PointLocation -> Invis [style=invis]
	Invis -> "its-core_Bearing" [style=invis]
	"its-core_Bearing" -> PointRepresentation [style=invis]
	"its-core_Bearing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Bearing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Bearing" margin=0]
	PointLocation -> "its-core_Bearing" [label=bearing arrowhead=normal style=solid]
	PointRepresentation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointRepresentation</TD></TR></TABLE>> URL="../PointRepresentation" margin=0]
	PointLocation -> PointRepresentation [label=hasPrimaryRepresentation arrowhead=normal style=solid]
	PointLocation -> PointRepresentation [label=hasAlternativeRepresentation arrowhead=normal style=solid]
}
