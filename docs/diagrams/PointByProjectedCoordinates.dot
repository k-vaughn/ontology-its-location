// Diagram for PointByProjectedCoordinates
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		PointByCoordinates [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointByCoordinates</TD></TR></TABLE>> URL="../PointByCoordinates" margin=0]
	}
	PointByProjectedCoordinates [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointByProjectedCoordinates</TD></TR><TR><TD ALIGN="LEFT">easting : xsd:decimal</TD></TR><TR><TD ALIGN="LEFT">northing : xsd:decimal</TD></TR></TABLE>> URL="../PointByProjectedCoordinates" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	PointByProjectedCoordinates -> PointByCoordinates [arrowhead=onormal style=solid]
}
