// Diagram for PointCoordinates
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
	}
	PointCoordinates [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointCoordinates</TD></TR><TR><TD ALIGN="LEFT">elevation : xsd:decimal [0..1]</TD></TR><TR><TD ALIGN="LEFT">latitude : xsd:decimal [1]</TD></TR><TR><TD ALIGN="LEFT">longitude : xsd:decimal [1]</TD></TR></TABLE>> URL="../PointCoordinates" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
}
