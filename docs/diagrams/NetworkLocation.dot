// Diagram for NetworkLocation
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Location</TD></TR></TABLE>> URL="../Location" margin=0]
	}
	NetworkLocation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">NetworkLocation</TD></TR></TABLE>> URL="../NetworkLocation" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		cdm3_NetworkElement [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm3:NetworkElement</TD></TR></TABLE>> URL="https://w3id.org/citydata/part3/v1/NetworkElement" margin=0]
	}
	NetworkLocation -> Location [arrowhead=onormal style=solid]
	NetworkLocation -> Invis [style=invis]
	Invis -> cdm3_NetworkElement [style=invis]
	cdm3_NetworkElement [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm3:NetworkElement</TD></TR></TABLE>> URL="https://w3id.org/citydata/part3/v1/NetworkElement" margin=0]
	NetworkLocation -> cdm3_NetworkElement [label="hasNetworkElement
1" arrowhead=normal style=solid]
}
