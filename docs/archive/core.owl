<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/itsdata/location/v1/"
     xml:base="https://w3id.org/itsdata/location/v1/"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cdm1="https://w3id.org/citydata/part1/v1/"
     xmlns:its-core="https://w3id.org/itsdata/core/v1/">

    <owl:Ontology rdf:about="https://w3id.org/itsdata/location/v1/Core/">
    	<!-- Identity -->
    	<dcterms:title>Core concepts of the Location Ontology for ITS</dcterms:title>
    	<skos:definition>This ontology defines concepts related to location within Intelligent Transportation Systems (ITS).</skos:definition>
    	<vann:preferredNamespaceUri>https://w3id.org/itsdata/location/v1/</vann:preferredNamespaceUri>
    	<vann:preferredNamespacePrefix>its-location</vann:preferredNamespacePrefix>
        <cdm1:mainModule>false</cdm1:mainModule>
        <its-core:draft>true</its-core:draft>
    		
    	<!-- Provenance -->
    	<dcterms:creator>Kenneth Vaughn</dcterms:creator>
        <dcterms:created>Draft</dcterms:created>
        <!-- Prior release - None -->
        <!-- This release -->
		<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-06</dcterms:modified>
        <owl:versionInfo>v0.0.2</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/itsdata/location/v1/Core/r0.2"/>
        <!-- TODO: I need to make sure that the above IRIs will work, in particular, the w3id redirect needs to be able to recognize that the r#.# extension is a release and not a class or property. -->
        
        <!-- License -->
        <dcterms:license>http://creativecommons.org/licenses/by/4.0/</dcterms:license>
        
        <!-- Imports -->
        <owl:imports rdf:resource="https://w3id.org/itsdata/core/v1/"/>
    </owl:Ontology>
    
    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://w3id.org/itsdata/location/v1/LocationObjectProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/LocationObjectProperty">
    	<skos:definition>An object property to organize all object properties defined in the Location Ontology.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSObjectProperty"/>
    </owl:ObjectProperty>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/location/v1/LocationDataProperty -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/LocationDataProperty">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSDataProperty"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/itsdata/location/v1/predefinedItineraryReference -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/predefinedItineraryReference">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationDataProperty"/>
    </owl:DatatypeProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/predefinedLocationGroupReference -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/predefinedLocationGroupReference">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationDataProperty"/>
    </owl:DatatypeProperty>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://w3id.org/itsdata/location/v1/LocationThing -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/LocationThing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSThing"/>
    </owl:Class>


</rdf:RDF>
