<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/itsdata/location/v1/"
     xml:base="https://w3id.org/itsdata/location/v1/"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cdm1="https://w3id.org/citydata/part1/v1/"
     xmlns:cdm2="https://w3id.org/citydata/part2/v1/"
     xmlns:its-core="https://w3id.org/itsdata/core/v1/">

    <owl:Ontology rdf:about="https://w3id.org/itsdata/location/v1/TPEGLocationPattern/">
    	<!-- Identity -->
    	<dcterms:title>TPEG Location concepts of the ITS Ontology</dcterms:title>
    	<skos:definition>This ontology defines concepts related to TPEG location within Intelligent Transportation Systems (ITS).</skos:definition>
    	<vann:preferredNamespaceUri>https://w3id.org/itsdata/location/v1/</vann:preferredNamespaceUri>
    	<vann:preferredNamespacePrefix>its-location</vann:preferredNamespacePrefix>
        <cdm1:mainModule>false</cdm1:mainModule>
        <its-core:draft>true</its-core:draft>
    		
    	<!-- Provenance -->
    	<dcterms:creator>Kenneth Vaughn</dcterms:creator>
        <dcterms:created>Draft</dcterms:created>
        <!-- Prior release - None -->
        <!-- This release -->
		<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-06</dcterms:modified>
        <owl:versionInfo>v0.0.2</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/itsdata/location/v1/TPEGLocationPattern/r0.2"/>
        
        <!-- License -->
        <dcterms:license>http://creativecommons.org/licenses/by/4.0/</dcterms:license>
        
        <!-- Imports -->
        <owl:imports rdf:resource="https://w3id.org/itsdata/location/v1/Core/"/>
    </owl:Ontology>
    
    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/location/v1/descriptorString -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/descriptorString">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/LocationDataProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegDescriptor"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <skos:definition xml:lang="en">A text string which describes or elaborates the location. Here is used for values distinct to RoadNumbers or AdministrativeUnit.</skos:definition>
    </owl:DatatypeProperty>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://w3id.org/itsdata/location/v1/descriptor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/descriptor">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegDescriptor"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/roads#RoadNumber"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <skos:definition>Describes or elaborates the location. Here is used for values from RoadNumber or AdministrativeUnit.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasCentrePoint -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasCentrePoint">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegGeometricArea"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/PointCoordinates"/>
        <skos:definition xml:lang="en">Centre point of a circular geometric area.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegAreaDescriptor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegAreaDescriptor">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegGeometricArea"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegNamedOnlyArea"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaDescriptor"/>
        <skos:definition xml:lang="en">Name of area.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegFramedPoint -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegFramedPoint">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegFramedPoint"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegNonJunctionPoint"/>
        <skos:definition xml:lang="en">A single non-junction point on the road network which is framed between two other specified points on the road network.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegHeight -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegHeight">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegHeight"/>
        <skos:definition xml:lang="en">Height information which provides additional discrimination for the applicable area.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegIlcPointDescriptor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegIlcPointDescriptor">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegJunction"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegIlcPointDescriptor"/>
        <skos:definition xml:lang="en">A descriptor for describing a junction by identifying the intersecting roads at a road junction.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegJunctionPointDescriptor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegJunctionPointDescriptor">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegJunction"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegJunctionPointDescriptor"/>
        <skos:definition xml:lang="en">A name which identifies a junction point on the road network</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegPoint -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegPoint">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegSimplePoint"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
        <skos:definition xml:lang="en">A single point defined by a coordinate set and TPEG descriptors.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegPointFrom -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegPointFrom">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegFramedPoint"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegLinearLocation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
        <skos:definition xml:lang="en">The location at the up stream end of the linear section of road.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegPointLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegPointLocation">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/PointLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegPointLocation"/>
        <skos:definition xml:lang="en">PointLocation is associated to TpegPointLocation with cardinality 0..1</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasTpegPointTo -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasTpegPointTo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegFramedPoint"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegLinearLocation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
        <skos:definition xml:lang="en">The location at the down stream end of the linear section of road.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/height -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/height">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegHeight"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/MetresAsFloatValue"/>
        <skos:definition xml:lang="en">A measurement of height in metres</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/radius -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/radius">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegGeometricArea"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/MetresAsNonNegativeIntegerValue"/>
        <skos:definition xml:lang="en">The radius of the corresponding circular area</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegAreaDescriptorType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegAreaDescriptorType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaDescriptor"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03AreaDescriptorSubtypeEnum"/>
        <skos:definition xml:lang="en">The nature of the descriptor used to define the location under consideration (derived from the TPEG Loc table 03).</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegAreaLocationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegAreaLocationType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc01AreaLocationSubtypeEnum"/>
        <skos:definition xml:lang="en">The type of TPEG location.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegDirection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegDirection">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegLinearLocation"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegPointLocation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/DirectionEnum"/>
        <skos:definition xml:lang="en">The direction of traffic flow.</skos:definition>
    </owl:ObjectProperty>


    <!-- https://w3id.org/itsdata/location/v1/tpegFramedPointLocationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegFramedPointLocationType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegFramedPoint"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc01FramedPointLocationSubtypeEnum"/>
        <skos:definition xml:lang="en">The type of TPEG location.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegHeightType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegHeightType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegHeight"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc04HeightTypeEnum"/>
        <skos:definition xml:lang="en">A descriptive identification of relative height using TPEG-Loc location referencing.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegIlcPointDescriptorType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegIlcPointDescriptorType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegIlcPointDescriptor"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03IlcPointDescriptorSubtypeEnum"/>
        <skos:definition xml:lang="en">The nature of the descriptor used to define the location under consideration (derived from the TPEG Loc table 03).</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegJunctionPointDescriptorType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegJunctionPointDescriptorType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegJunctionPointDescriptor"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03JunctionPointDescriptorSubtypeEnum"/>
        <skos:definition xml:lang="en">The nature of the descriptor used to define the location under consideration (derived from the TPEG Loc table 03).</skos:definition>
    </owl:ObjectProperty>
    
    <!-- https://w3id.org/itsdata/location/v1/tpegLinearLocationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegLinearLocationType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegLinearLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TPEGLoc01LinearLocationSubtypeEnum"/>
        <skos:definition xml:lang="en">The type of TPEG location.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegOtherPointDescriptorType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegOtherPointDescriptorType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegOtherPointDescriptor"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03OtherPointDescriptorSubtypeEnum"/>
        <skos:definition xml:lang="en">The nature of the descriptor used to define the location under consideration (derived from the TPEG Loc table 03).</skos:definition>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/tpegSimplePointLocationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/tpegSimplePointLocationType">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/TpegSimplePoint"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc01SimplePointLocationSubtypeEnum"/>
        <skos:definition xml:lang="en">The type of TPEG location.</skos:definition>
    </owl:ObjectProperty>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    
    <!-- https://w3id.org/itsdata/location/v1/TpegAreaDescriptor -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegAreaDescriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegDescriptor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegAreaDescriptorType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03AreaDescriptorSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A descriptor for describing an area location.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegAreaLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegAreaLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegAreaLocationType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc01AreaLocationSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegHeight"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegHeight"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A geographic or geometric area defined by a TPEG-Loc structure which may include height information for additional geospatial discrimination</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegDescriptor -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegDescriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/descriptor"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit"/>
                            <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/roads#RoadNumber"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/descriptorString"/>
                <owl:onDataRange rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
                <!-- SingleMultilingualShape -->
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A collection of information providing descriptive references to locations using the TPEG-Loc location referencing approach.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegEnumerations -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegEnumerations">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/Enums"/>
        <skos:definition xml:lang="en">Only for organizational purposes</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegFramedPoint -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegFramedPoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPointLocation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegFramedPoint"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegNonJunctionPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegPointFrom"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegPointTo"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegFramedPointLocationType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc01FramedPointLocationSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A point on the road network which is framed between two other points on the same road.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegGeometricArea -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegGeometricArea">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaLocation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasCentrePoint"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/PointCoordinates"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/radius"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/MetresAsNonNegativeIntegerValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegAreaDescriptor"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaDescriptor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A geometric area defined by a centre point and a radius.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegHeight -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegHeight">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegHeightType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc04HeightTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/height"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/MetresAsFloatValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Height information which provides additional discrimination for the applicable area.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegIlcPointDescriptor -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegIlcPointDescriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPointDescriptor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegIlcPointDescriptorType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03IlcPointDescriptorSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A descriptor for describing a junction by defining the intersecting roads.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegJunction -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegJunction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegIlcPointDescriptor"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegIlcPointDescriptor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegIlcPointDescriptor"/>
                        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:maxQualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegIlcPointDescriptor"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegJunctionPointDescriptor"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegJunctionPointDescriptor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/itsdata/location/v1/TpegNonJunctionPoint"/>
        <skos:definition xml:lang="en">A point on the road network which is a road junction point.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegJunctionPointDescriptor -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegJunctionPointDescriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPointDescriptor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegJunctionPointDescriptorType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03JunctionPointDescriptorSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A descriptor for describing a point at a junction on a road network.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLinearLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLinearLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegPointTo"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/DirectionEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegLinearLocationType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TPEGLoc01LinearLocationSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A linear section along a single road defined between two points on the same road by a TPEG-Loc structure.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationObjects"/>
        <skos:definition xml:lang="en">Tpeg location</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc01AreaLocationSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc01AreaLocationSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/largeArea"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/other"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Types of area.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc01FramedPointLocationSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc01FramedPointLocationSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/framedPoint"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Types of points on the road network framed by two other points on the same road.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc01SimplePointLocationSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc01SimplePointLocationSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/intersection"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/nonLinkedPoint"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Types of simple point.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc03AreaDescriptorSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc03AreaDescriptorSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/administrativeAreaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/administrativeReferenceName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/areaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/countyName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/lakeName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/nationName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/other"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/policeForceControlAreaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/regionName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/seaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/townName"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Descriptors for describing area locations.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc03IlcPointDescriptorSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc03IlcPointDescriptorSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/tpegIlcName1"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/tpegIlcName2"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/tpegIlcName3"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Descriptors for describing a junction by identifying the intersecting roads at a road junction.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc03JunctionPointDescriptorSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc03JunctionPointDescriptorSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/junctionName"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Descriptors for describing a point at a road junction.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc03OtherPointDescriptorSubtypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc03OtherPointDescriptorSubtypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/administrativeAreaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/administrativeReferenceName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/airportName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/areaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/buildingName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/busStopIdentifier"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/busStopName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/canalName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/countyName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/ferryPortName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/intersectionName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/lakeName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/linkName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/localLinkName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/metroStationName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/nationName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/nonLinkedPointName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/other"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/parkingFacilityName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/pointName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/pointOfInterestName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/railwayStation"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/regionName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/riverName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/seaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/serviceAreaName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/tidalRiverName"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/townName"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Descriptors other than junction names and road descriptors which can help to identify the location of points on the road network.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegLoc04HeightTypeEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegLoc04HeightTypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/aboveSeaLevelTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/aboveStreetLevelTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/aboveTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/atSeaLevelTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/atStreetLevelTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/atTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/belowSeaLevelTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/belowStreetLevelTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/belowTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/other"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/undefinedTPEGHeight"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/unknown"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegEnumerations"/>
        <skos:definition xml:lang="en">Types of height.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegNamedOnlyArea -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegNamedOnlyArea">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaLocation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegAreaDescriptor"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/itsdata/location/v1/TpegAreaDescriptor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">An area defined by a well-known name.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegNonJunctionPoint -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegNonJunctionPoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegOtherPointDescriptor"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegOtherPointDescriptor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A point on the road network which is not a road junction point.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegOtherPointDescriptor -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegOtherPointDescriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPointDescriptor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegOtherPointDescriptorType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc03OtherPointDescriptorSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">General descriptor for describing a point.</skos:definition>
    </owl:Class>


    <!-- https://w3id.org/itsdata/location/v1/TpegPointDescriptor -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegPointDescriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegDescriptor"/>
        <skos:definition xml:lang="en">A descriptor for describing a point location.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegPointLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegPointLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/DirectionEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A single point on the road network defined by a TPEG-Loc structure and which has an associated direction of traffic flow.</skos:definition>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegSimplePoint -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegSimplePoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegPointLocation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasTpegPoint"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/tpegSimplePointLocationType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc01SimplePointLocationSubtypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A point on the road network which is not bounded by any other points on the road network.</skos:definition>
    </owl:Class>


</rdf:RDF>