BASE <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX cdm1: <https://w3id.org/citydata/part1/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>
PREFIX sf: <http://www.opengis.net/ont/sf#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>


:AltitudeConfidenceShape a sh:NodeShape ;
    sh:targetClass :AltitudeConfidence ;
    sh:property [
        sh:path :altitudeAccuracyCodedError ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype :PositionConfidenceErrorCode ;
    ] ;
    sh:property [
        sh:path :altitudeAccuracyCodedValue ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype :AltitudeAccuracyCode ;
    ] .

:AreaDestinationShape a sh:NodeShape ;
    sh:targetClass :AreaDestination ;
    sh:property [
        sh:path :hasAreaLocation ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AreaLocation ;
    ] .

:AreaLocationShape a sh:NodeShape ;
    sh:targetClass :AreaLocation ;
    sh:property [
        sh:path :areasAtWhichApplicable ;
        sh:node its-sh:MaxOneShape ;
        sh:class :AreaPlacesCode ;
    ] ;
    sh:property [
        sh:path :hasAlertCArea ;
        sh:class :AlertCArea ;
    ] ;
    sh:property [
        sh:path :hasTpegAreaLocation ;
        sh:node its-sh:MaxOneShape ;
        sh:class :TpegAreaLocation ;
    ] ;
    sh:property [
        sh:path :hasNamedArea ;
        sh:node its-sh:MaxOneShape ;
        sh:class :NamedArea ;
    ] ;
    sh:property [
        sh:path :hasMultiPolygon ;
        sh:node its-sh:MaxOneShape ;
        sh:class sf:MultiPolygon ;
    ] ;
    sh:property [
        sh:path :hasOpenLRAreaLocationReference ;
        sh:node its-sh:MaxOneShape ;
        sh:class :OpenLRAreaLocationReference ;
    ] .

:DestinationShape a sh:NodeShape ;
    sh:targetClass :Destination .

:ExternalReferencingShape a sh:NodeShape ;
    sh:targetClass :ExternalReferencing ;
    sh:property [
        sh:path :externalLocationCode ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :externalReferencingSystem ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] .

:HeightCoordinateShape a sh:NodeShape ;
    sh:targetClass :HeightCoordinate ;
    sh:property [
        sh:path :heightType ;
        sh:node its-sh:MaxOneShape ;
        sh:class :HeightTypeCode ;
    ] ;
    sh:property [
        sh:path :heightValue ;
        sh:node its-sh:ExactlyOneShape ;
        sh:hasValue cdm1:Length ;
    ] ;
    sh:property [
        sh:path :verticalPositionAccuracy ;
        sh:node its-sh:MaxOneShape ;
        sh:class :PositionAccuracy ;
    ] ;
    sh:property [
        sh:path :hasAltitudeConfidence ;
        sh:node its-sh:MaxOneShape ;
        sh:class :AltitudeConfidence ;
    ] .

:ItineraryShape a sh:NodeShape ;
    sh:targetClass :Itinerary ;
    sh:property [
        sh:path :routeDestination ;
        sh:class :Destination ;
    ] .

:ItineraryByIndexedLocationsShape a sh:NodeShape ;
    sh:targetClass :ItineraryByIndexedLocations ;
    sh:property [
        sh:path :locationContainedInItinerary ;
        sh:minCount 2 ;
        sh:class :IndexedLocation ;
    ] ;
    # Enforces unique indices within the same itinerary
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Indices of IndexedLocations within an ItineraryByIndexedLocations must be unique." ;
        sh:select """
            PREFIX : <https://w3id.org/itsdata/location/v1/>
            SELECT $this ?index ?loc1 ?loc2
            WHERE {
                $this a :ItineraryByIndexedLocations .
                ?loc1 :locationContainedInItinerary $this ;
                      :index ?index .
                ?loc2 :locationContainedInItinerary $this ;
                      :index ?index .
                FILTER (?loc1 != ?loc2)
            }
        """ ;
    ] .

:LinearLocationShape a sh:NodeShape ;
    sh:targetClass :LinearLocation ;
    sh:property [
        sh:path :secondarySupplementaryDescription ;
        sh:node its-sh:MaxOneShape ;
        sh:class :SupplementaryPositionalDescription ;
    ] ;
    sh:property [
        sh:path :hasLineString ;
        sh:node its-sh:MaxOneShape ;
        sh:class sf:LineString ;
    ] ;
    sh:property [
        sh:path :hasOpenLRLinear ;
        sh:node its-sh:MaxOneShape ;
        sh:class :OpenLRLinear ;
    ] .

:NetworkLocationShape a sh:NodeShape ;
    sh:targetClass :NetworkLocation ;
    sh:property [
        sh:path :hasPositionalDescription ;
        sh:node its-sh:MaxOneShape ;
        sh:class :SupplementaryPositionalDescription ;
    ] ;
    sh:property [
        sh:path :hasDestination ;
        sh:node its-sh:MaxOneShape ;
        sh:class :Destination ;
    ] .

# :PlaceShape a sh:NodeShape ;
#    sh:targetClass :Place ;
#    sh:property [
#        sh:path :placeType ;
#        sh:node its-sh:ExactlyOneShape ;
#        sh:class :PlaceTypeCode ;
#    ] ;
