:PointCoordinatesShape a sh:NodeShape ;
    sh:targetClass :PointCoordinates ;
    sh:property [
        sh:path :latitude ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:decimal ;
    ] ;
    sh:property [
        sh:path :longitude ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:decimal ;
    ] ;
    sh:property [
        sh:path :elevation ;
        sh:maxCount 3 ;
        sh:datatype :HeightCoordinate ;
        sh:message "Elevation can have up to three values, representing ellipsoidal height, gravity-related height, and height from ground level." ;
    ] ;
    sh:property [
        sh:path cdm1:hasIdentifier ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :hasPositionConfidenceEllipse ;
        sh:node its-sh:MaxOneShape ;
        sh:class :PositionConfidenceEllipse ;
    ] ;
    sh:property [
        sh:path :hasPositionAccuracy ;
        sh:node its-sh:MaxOneShape ;
        sh:class :PositionAccuracy ;
    ] .

:PointDestinationShape a sh:NodeShape ;
    sh:targetClass :PointDestination ;
    sh:property [
        sh:path :hasPointLocation ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :PointLocation ;
    ] .
:PointLocationShape a sh:NodeShape ;
    sh:targetClass :PointLocation ;
    sh:property [
        sh:path :hasPointByCoordinates ;
        sh:node its-sh:MaxOneShape ;
        sh:class :PointByCoordinates ;
    ] ;
    sh:property [
        sh:path :hasPointAlongLinearElement ;
        sh:node its-sh:MaxOneShape ;
        sh:class :PointAlongLinearElement ;
    ] ;
    sh:property [
        sh:path :hasTpegPointLocation ;
        sh:node its-sh:MaxOneShape ;
        sh:class :TpegPointLocation ;
    ] ;
    sh:property [
        sh:path :hasAlertCPoint ;
        sh:node its-sh:MaxOneShape ;
        sh:class :AlertCPoint ;
    ] ;
    sh:property [
        sh:path :hasOpenLRPointLocationReference ;
        sh:node its-sh:MaxOneShape ;
        sh:class :OpenLRPointLocationReference ;
    ] .

:PositionAccuracyShape a sh:NodeShape ;
    sh:targetClass :PositionAccuracy ;
    sh:property [
        sh:path :accuracyPercentile50 ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype cdm1:Length ;
    ] ;
    sh:property [
        sh:path :accuracyPercentile75 ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype cdm1:Length ;
    ] ;
    sh:property [
        sh:path :accuracyPercentile95 ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype cdm1:Length ;
    ] .

:PositionConfidenceEllipseShape a sh:NodeShape ;
    sh:targetClass :PositionConfidenceEllipse ;
    sh:property [
        sh:path :semiMajorAxisLength ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype cdm1:Length ;
    ] ;
    sh:property [
        sh:path :semiMajorAxisLengthCodedError ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype :PositionConfidenceErrorCode ;
    ] ;
    sh:property [
        sh:path :semiMajorAxisOrientation ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype :Angle ;
    ] ;
    sh:property [
        sh:path :semiMajorAxisOrientationError ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype xsd:boolean ;
    ] ;
    sh:property [
        sh:path :semiMinorAxisLength ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype cdm1:Length ;
    ] ;
    sh:property [
        sh:path :semiMinorAxisLengthCodedError ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype :PositionConfidenceErrorCode ;
    ] .

:SupplementaryPositionalDescriptionShape a sh:NodeShape ;
    sh:targetClass :SupplementaryPositionalDescription ;
    sh:property [
        sh:path :hasDirectionPurpose ;
        sh:node its-sh:MaxOneShape ;
        sh:class :DirectionPurposeCode ;
    ] ;
    sh:property [
        sh:path :hasGeographicDescriptor ;
        sh:node its-sh:MaxOneShape ;
        sh:class :GeographicCharacteristicCode ;
    ] ;
    sh:property [
        sh:path :hasInfrastructureDescriptor ;
        sh:node its-sh:MaxOneShape ;
        sh:class :InfrastructureDescriptorCode ;
    ] ;
    sh:property [
        sh:path :lengthAffected ;
        sh:node its-sh:MaxOneShape ;
        sh:class cdm1:Length ;
    ] ;
    sh:property [
        sh:path :locationDescription ;
        sh:node its-sh:MaxOneShape ;
        sh:node :SingleMultilingualShape ;
    ] ;
    sh:property [
        sh:path :locationPrecision ;
        sh:node its-sh:MaxOneShape ;
        sh:class cdm1:Length
    ] ;
    sh:property [
        sh:path :hasPositionOnCarriageway ;
        sh:node its-sh:MaxOneShape ;
        sh:class :PositionOnCarriagewayCode ;
    ] ;
    sh:property [
        sh:path :sequentialRampNumber ;
        sh:node its-sh:MaxOneShape ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;
    sh:property [
        sh:path :hasRoadInformation ;
        sh:class :RoadInformation ;
    ] ;
    sh:property [
        sh:path :hasCarriageway ;
        sh:class :Carriageway ;
    ] ;
    sh:property [
        sh:path :hasNamedArea ;
        sh:node its-sh:MaxOneShape ;
        sh:class :NamedArea ;
     ] .
