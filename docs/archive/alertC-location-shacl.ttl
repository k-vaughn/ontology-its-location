BASE   <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>

:AlertCLocationSHACL a owl:Ontology;
    # Ontology metadata
    dcterms:title          "The SHACL rules for the Alert C concepts of the Location Ontology for ITS";
    skos:definition        "This ontology defines SHACL rules related to Alert C location within Intelligent Transportation Systems (ITS).";
    dcterms:license        "http://creativecommons.org/licenses/by/4.0/";
    its-core:draft         "true";
    
    #Provenance metadata
    dcterms:creator        "Kenneth Vaughn";
    dcterms:created        "Draft";
    dcterms:modified       "2026-04-07"^^xsd:date;
    owl:versionInfo        "0.0.3";
    owl:versionIRI         <AlertCLocationSHACL/r0.3>;
    owl:priorVersion       <AlertCLocationSHACL/r0.2> .
    
:AlertCLocationCodeShape a sh:NodeShape;
    sh:datatype         xsd:nonNegativeInteger ;
    sh:minInclusive     1 ;
    sh:maxInclusive     63487 ;
    sh:minCount         1 ;
    sh:maxCount         1 ;
    sh:targetClass      :AlertCLocationCode ;
    sh:message          "The AlertCLocationCode must be an integer in the range 1..63487"@en;
    skos:definition     "Unique code within an ALERT-C location table which identifies the specific point, linear or area location. A positive integer number (between 1 and 63487) which uniquely identifies a pre-defined Alert C location."@en;
    skos:note           "NOTE: Some tools have difficulty in properly interpreting the following and translate AlertCLocationCode to a Class and associated properties to ObjectProperties."@en .


:AlertCAreaShape a sh:NodeShape;
    sh:targetClass :AlertCArea;
    sh:property [
        sh:path :hasAlertCLocation;
        sh:node its-sh:ExactlyOneShape;
        sh:class :AlertCLocation ;
    ] ;
    sh:property [
        sh:path :alertCLocationCountryCode;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :alertCLocationTableNumber;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :alertCLocationTableVersion;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] .

:AlertCDirectionShape a sh:NodeShape;
    sh:targetClass :AlertCDirection;
    sh:property [
        sh:path :hasAlertCAffectedDirection;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :LinearDirectionEnum ;
    ] ;
    sh:property [
        sh:path :hasAlertCDirectionCoded;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCDirectionEnum ;
    ] .

:AlertCLinearShape a sh:NodeShape;
    sh:targetClass :AlertCLinear;
    sh:property [
        sh:path :alertCLocationCountryCode;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :alertCLocationTableNumber;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :alertCLocationTableVersion;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] .

:AlertCLinearByCodeShape a sh:NodeShape;
    sh:targetClass :AlertCLinearByCode ;
    sh:property [
        sh:path :hasLocationCodeForLinearLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCLocation ;
    ] ;
    sh:property [
        sh:path :hasAlertCDirection;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCDirection ;
    ] .
:AlertCLocationShape a sh:NodeShape;
    sh:targetClass :AlertCLocation ;
    sh:property [
        sh:path :specificLocation;
        sh:node :AlertCLocationCodeShape ;
    ] .

:AlertCMethod2LinearShape a sh:NodeShape;
    sh:targetClass :AlertCMethod2Linear ;
    sh:property [
        sh:path :hasAlertCDirection;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCDirection ;
    ] ;
    sh:property [
        sh:path :hasAlertCMethod2PrimaryPointLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCMethod2PrimaryPointLocation ;
    ] ;
    sh:property [
        sh:path :hasAlertCMethod2SecondaryPointLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCMethod2SecondaryPointLocation ;
    ] .

:AlertCMethod2PointShape a sh:NodeShape;
    sh:targetClass :AlertCMethod2Point ;
    sh:property [
        sh:path :hasAlertCDirection;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCDirection ;
    ] ;
    sh:property [
        sh:path :hasAlertCMethod2PrimaryPointLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCMethod2PrimaryPointLocation ;
    ] .

:AlertCMethod2PrimaryPointLocationShape a sh:NodeShape;
    sh:targetClass :AlertCMethod2PrimaryPointLocation ;
    sh:property [
        sh:path :hasAlertCLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCLocation ;
    ] .

:AlertCMethod2SecondaryPointLocationShape a sh:NodeShape;
    sh:targetClass :AlertCMethod2SecondaryPointLocation ;
    sh:property [
        sh:path :hasAlertCLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCLocation ;
    ] .

:AlertCMethod4LinearShape a sh:NodeShape;
    sh:targetClass :AlertCMethod4Linear ;
    sh:property [
        sh:path :hasAlertCDirection;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCDirection ;
    ] ;
    sh:property [
        sh:path :hasAlertCMethod4PrimaryPointLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCMethod4PrimaryPointLocation ;
    ] ;
    sh:property [
        sh:path :hasAlertCMethod4SecondaryPointLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCMethod4SecondaryPointLocation ;
    ] .

:AlertCMethod4PointShape a sh:NodeShape;
    sh:targetClass :AlertCMethod4Point ;
    sh:property [
        sh:path :hasAlertCDirection;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCDirection ;
    ] ;
    sh:property [
        sh:path :hasAlertCMethod4PrimaryPointLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCMethod4PrimaryPointLocation ;
    ] .

:AlertCMethod4PrimaryPointLocationShape a sh:NodeShape;
    sh:targetClass :AlertCMethod4PrimaryPointLocation ;
    sh:property [
        sh:path :hasAlertCLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCLocation ;
    ] ;
    sh:property [
        sh:path :hasOffsetDistance;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :OffsetDistance ;
    ] .

:AlertCMethod4SecondaryPointLocationShape a sh:NodeShape;
    sh:targetClass :AlertCMethod4SecondaryPointLocation ;
    sh:property [
        sh:path :hasAlertCLocation;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :AlertCLocation ;
    ] ;
    sh:property [
        sh:path :hasOffsetDistance;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :OffsetDistance ;
    ] .

:AlertCPointShape a sh:NodeShape;
    sh:targetClass :AlertCPoint ;
    sh:property [
        sh:path :alertCLocationCountryCode;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :alertCLocationTableNumber;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :alertCLocationTableVersion;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] .

:OffsetDistanceShape a sh:NodeShape;
    sh:targetClass :OffsetDistance ;
    sh:property [
        sh:path :offsetDistance;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :MetresAsNonNegativeIntegerValue ;
    ] .
:TPEGPointShape a sh:NodeShape;
    sh:targetClass :TPEGPoint ;
    sh:property [
        sh:path :hasPointCoordinates;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :PointCoordinates ;
    ] .
