BASE   <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>

:ExternalLocationSHACL a owl:Ontology;
    # Ontology metadata
    dcterms:title          "The SHACL rules for the External Location Ontology for ITS";
    skos:definition        "This ontology defines SHACL rules related to externally defined locations within Intelligent Transportation Systems (ITS).";
    dcterms:license        "http://creativecommons.org/licenses/by/4.0/";
    its-core:draft         "true";
    
    #Provenance metadata
    dcterms:creator        "Kenneth Vaughn";
    dcterms:created        "Draft";
    dcterms:modified       "2026-04-09"^^xsd:date;
    owl:versionInfo        "0.0.4";
    owl:versionIRI         <LocationSHACL/r0.4>;
    owl:priorVersion       <LocationSHACL/r0.3> .
    
:ExternalReferenceShape a sh:NodeShape ;
    sh:targetClass :ExternalReference ;
    sh:property [
        sh:path :externalLocationCode ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path :externalReferencingSystem ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:string ;
    ] .