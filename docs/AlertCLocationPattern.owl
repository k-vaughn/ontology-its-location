<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/itsdata/location/v1/"
     xml:base="https://w3id.org/itsdata/location/v1/"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cdm1="https://w3id.org/citydata/part1/v1/"
     xmlns:cdm2="https://w3id.org/citydata/part2/v1/"
     xmlns:its-core="https://w3id.org/itsdata/core/v1/">

    <owl:Ontology rdf:about="https://w3id.org/itsdata/location/v1/AlertCLocationPattern/">
    	<!-- Identity -->
    	<dcterms:title>Alert C concepts of the Location Ontology for ITS</dcterms:title>
    	<skos:definition>This ontology defines concepts related to Alert C location within Intelligent Transportation Systems (ITS).</skos:definition>
    	<vann:preferredNamespaceUri>https://w3id.org/itsdata/location/v1/AlertCLocationPattern/</vann:preferredNamespaceUri>
    	<vann:preferredNamespacePrefix>its-location</vann:preferredNamespacePrefix>
        <cdm1:mainModule>false</cdm1:mainModule>
        <its-core:draft>true</its-core:draft>
    		
    	<!-- Provenance -->
    	<dcterms:creator>Kenneth Vaughn</dcterms:creator>
        <dcterms:created>Draft</dcterms:created>
        <dcterms:source xml:lang="en">https://docs.datex2.eu/_static/data/v3.7/umlmodel/html/index.htm</dcterms:source>
        <dcterms:source>http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti</dcterms:source>
        <dcterms:contributor>Tam Tam Research, CVUT, ESAM Technologies &amp; LMT.</dcterms:contributor>
        <dcterms:contributor>Julian Gutierrez Moret (https://www.uv.es/uvweb/universidad/es/ficha-persona-1285950309813.html?p2=gumoju)</dcterms:contributor>
        <rdfs:comment>This ontology was derived from the dtx_srti ontology, which was derived from the DATEX II v3.2 model; it has been updated to consider changes made up to DATEX II v3.7 and revised to support more generic representations, such as deriving classes from the City Data Model and other ontologies.</rdfs:comment>


        <!-- Prior release - None -->
        <!-- This release -->
		<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-24</dcterms:modified>
        <owl:versionInfo>v0.0.2</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocationPattern/r0.2"/>
        <!-- TODO: I need to make sure that the above IRIs will work, in particular, the w3id redirect needs to be able to recognize that the r#.# extension is a release and not a class or property. -->
        
        <!-- License -->
        <dcterms:license>http://creativecommons.org/licenses/by/4.0/</dcterms:license>
        
        <!-- Imports -->
        <owl:imports rdf:resource="https://w3id.org/itsdata/location/v1/Core/"/>
    </owl:Ontology>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- http://datex2.eu/schema/3/common#AlertCLocationCode -->

    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/common#AlertCLocationCode">
        <skos:definition>Unique code within an ALERT-C location table which identifies the specific point, linear or area location. A positive integer number (between 1 and 63487) which uniquely identifies a pre-defined Alert C location.</skos:definition>
        <rdfs:comment>NOTE: Some tools have difficulty in properly interpreting the following and translate AlertCLocationCode to a Class and associated properties to ObjectProperties.</rdfs:comment>
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">63487</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </owl:equivalentClass>
    </rdfs:Datatype>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/location/v1/hasAlertCAffectedDirection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCAffectedDirection">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/LinearDirectionEnum"/>
        <rdfs:comment xml:lang="en">The direction(s) of traffic flow to which the situation, traffic data or information is related.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasAlertCDirection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCDirection">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCLinearByCode"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2Linear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2Point"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4Linear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4Point"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
        <rdfs:comment xml:lang="en">ALERT-C direction</rdfs:comment>
        <rdfs:comment xml:lang="en">The direction of traffic flow along the road to which the information relates.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/location/v1/hasAlertCDirectionCoded -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCDirectionCoded">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirectionEnum"/>
        <rdfs:comment xml:lang="en">Direction of navigation with respect to secondary to primary location (RDS direction)</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasAlertCLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCLocation">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCArea"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2PrimaryPointLocation"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2SecondaryPointLocation"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4SecondaryPointLocation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
        <rdfs:comment xml:lang="en">ALERT-C location</rdfs:comment>
        <rdfs:comment xml:lang="en">Identification of a specific point, linear or area location in an ALERT-C location table.</rdfs:comment>
    </owl:ObjectProperty>
    
    <!-- https://w3id.org/itsdata/location/v1/hasAlertCMethod2PrimaryPointLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCMethod2PrimaryPointLocation">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2Linear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2Point"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod2PrimaryPointLocation"/>
        <rdfs:comment xml:lang="en">ALERT-C method2 primary point location</rdfs:comment>
        <rdfs:comment xml:lang="en">The point (called Primary point) which is either a single point or at the downstream end of a linear road section. The point is specified by a reference to a point in a pre-defined ALERT-C location table.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasAlertCMethod2SecondaryPointLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCMethod2SecondaryPointLocation">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod2Linear"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod2SecondaryPointLocation"/>
        <rdfs:comment xml:lang="en">ALERT-C method2 secondary point location</rdfs:comment>
        <rdfs:comment xml:lang="en">The point (called Secondary point) which is at the upstream end of a linear road section. The point is specified by a reference to a point in a pre-defined ALERT-C location table.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasAlertCMethod4PrimaryPointLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCMethod4PrimaryPointLocation">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4Linear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4Point"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation"/>
        <rdfs:comment xml:lang="en">ALERT-C method4 primary point location</rdfs:comment>
        <rdfs:comment xml:lang="en">The point (called Primary point) which is either a single point or at the downstream end of a linear road section. The point is specified by a reference to a point in a pre-defined ALERT-C location table plus a non-negative offset distance.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasAlertCMethod4SecondaryPointLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasAlertCMethod4SecondaryPointLocation">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod4Linear"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod4SecondaryPointLocation"/>
        <rdfs:comment xml:lang="en">ALERT-C method4 secondary point location</rdfs:comment>
        <rdfs:comment xml:lang="en">The point (called Secondary point) which is at the upstream end of a linear road section. The point is specified by a reference to a point in a pre-defined Alert-C location table plus a non-negative offset distance.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasLocationCodeForLinearLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasLocationCodeForLinearLocation">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLinearByCode"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
        <rdfs:comment xml:lang="en">Specific location. Unique code within the ALERT-C location table which identifies the specific point, linear or area location.Unique code within the ALERT-C location table which identifies the specific point, linear or area location.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasOffsetDistance -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasOffsetDistance">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4SecondaryPointLocation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/OffsetDistance"/>
        <rdfs:comment xml:lang="en">The non-negative offset distance from the ALERT-C referenced point to the actual point.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/hasPointCoordinates -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/hasPointCoordinates">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/Location"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/OpenlrBaseReferencePoint"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/OpenlrPolygonCorners"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/OpenlrRectangle"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/PointByCoordinates"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/Referent"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegJunction"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/TpegNonJunctionPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/PointCoordinates"/>
        <rdfs:comment xml:lang="en">Coordinates that may be used by clients for visual display on user interfaces.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/offsetDistance -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/location/v1/offsetDistance">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/OffsetDistance"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/location/v1/MetresAsNonNegativeIntegerValue"/>
        <rdfs:comment xml:lang="en">The non-negative offset distance from the ALERT-C referenced point to the actual point. The ALERT-C locations in the primary and secondary locations must always encompass the linear section being specified, thus offset distance is towards the other point.</rdfs:comment>
    </owl:ObjectProperty>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatype Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/location/v1/alertCLocationCountryCode -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/alertCLocationCountryCode">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCArea"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCLinear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">ALERT-C country code as defined in IEC 62106.</rdfs:comment>
    </owl:DatatypeProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/alertCLocationTableNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/alertCLocationTableNumber">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCArea"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCLinear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Number allocated to an ALERT-C table in a country. Ref. EN ISO 14819-3 for the allocation of a location table number.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/itsdata/location/v1/alertCLocationTableVersion -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/alertCLocationTableVersion">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCArea"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCLinear"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/AlertCPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Version number associated with an ALERT-C table reference.</rdfs:comment>
    </owl:DatatypeProperty>
    

    <!-- https://w3id.org/itsdata/location/v1/specificLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/location/v1/specificLocation">
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
        <rdfs:range rdf:resource="http://datex2.eu/schema/3/Common/3_1#AlertCLocationCode"/>
        <rdfs:comment>Unique code within the ALERT-C location table which identifies the specific point, linear or area location.</rdfs:comment>
    </owl:DatatypeProperty>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/location/v1/LocationThing -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/LocationThing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/core/ITSThing"/>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertC -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCThing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationThing"/>
        <rdfs:comment xml:lang="en">Alert C location</rdfs:comment>
    </owl:Class>


    <!-- https://w3id.org/itsdata/location/v1/AlertCArea -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCArea">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationCountryCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationTableNumber"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationTableVersion"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An area defined by reference to a predefined ALERT-C location table.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCDirection -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCDirection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCAffectedDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/LinearDirectionEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCDirectionCoded"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirectionEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
        <rdfs:comment xml:lang="en">The direction of traffic flow along the road to which the information relates.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCDirectionEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCDirectionEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/both"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/negative"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/positive"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationReferencingEnumerations"/>
        <rdfs:comment xml:lang="en">Direction used to reach the primary location from the secondary location in ALERT-C location table, as defined in CEN ISO 14819-1</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCLinear -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCLinear">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationCountryCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationTableNumber"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationTableVersion"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A linear section along a road defined between two points on the road by reference to a pre-defined ALERT-C location table. When there are multiple instances of AlertCLinear they should represent the same location using different location tables.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCLinearByCode -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCLinearByCode">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLinear"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasLocationCodeForLinearLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A linear section along a road defined by reference to a linear section in a pre-defined ALERT-C location table.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:comment xml:lang="en">Identification of a specific point, linear or area location in an ALERT-C location table.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod2Linear -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2Linear">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLinear"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCMethod2PrimaryPointLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod2PrimaryPointLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCMethod2SecondaryPointLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod2SecondaryPointLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A linear section along a road between two points, primary and secondary, which are pre-defined in an ALERT-C location table. Direction is FROM the secondary point TO the primary point, i.e. the primary point is downstream of the secondary point.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod2Point -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2Point">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCPoint"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCMethod2PrimaryPointLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod2PrimaryPointLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A single point on the road network defined by reference to a point in a pre-defined ALERT-C location table and which has an associated direction of traffic flow.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod2PrimaryPointLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2PrimaryPointLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The point (called Primary point) which is either a single point or at the downstream end of a linear road section. The point is specified by a reference to a point in a pre-defined ALERT-C location table.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod2SecondaryPointLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod2SecondaryPointLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The point (called Secondary point) which is at the upstream end of a linear road section. The point is specified by a reference to a point in a pre-defined ALERT-C location table.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod4Linear -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4Linear">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLinear"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCMethod4PrimaryPointLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCMethod4SecondaryPointLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod4SecondaryPointLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A linear section along a road between two points, primary and secondary, which are pre-defined ALERT-C locations plus offset distance. Direction is FROM the secondary point TO the primary point, i.e. the primary point is downstream of the secondary point.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod4Point -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4Point">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCPoint"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCDirection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCMethod4PrimaryPointLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A single point on the road network defined by reference to a point in a pre-defined ALERT-C location table plus an offset distance and which has an associated direction of traffic flow.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4PrimaryPointLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasOffsetDistance"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/OffsetDistance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The point (called Primary point) which is either a single point or at the downstream end of a linear road section. The point is specified by a reference to a point in a pre-defined ALERT-C location table plus a non-negative offset distance.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCMethod4SecondaryPointLocation -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCMethod4SecondaryPointLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasAlertCLocation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/AlertCLocation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasOffsetDistance"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/OffsetDistance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The point (called Secondary point) which is at the upstream end of a linear road section. The point is specified by a reference to a point in a pre-defined Alert-C location table plus a non-negative offset distance.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/AlertCPoint -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/AlertCPoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/AlertCThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationCountryCode"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationTableNumber"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/alertCLocationTableVersion"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/itsdata/location/v1/TpegPoint"/>
        <rdfs:comment xml:lang="en">A single point on the road network defined by reference to a pre-defined ALERT-C location table and which has an associated direction of traffic flow.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/LinearDirectionEnum -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/LinearDirectionEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/aligned"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/both"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/opposite"/>
                    <rdf:Description rdf:about="https://w3id.org/itsdata/location/v1/unknown"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationReferencingEnumerations"/>
        <rdfs:comment xml:lang="en">Directions of traffic flow relative to the direction in which the linear element is defined.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/LocationReferencingEnumerations -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/LocationReferencingEnumerations">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/Enums"/>
        <rdfs:comment xml:lang="en">Only for organizational purposes</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/OffsetDistance -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/OffsetDistance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/LocationReferencing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/offsetDistance"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/MetresAsNonNegativeIntegerValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The non-negative offset distance from the ALERT-C referenced point to the actual point.</rdfs:comment>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/location/v1/TpegPoint -->

    <owl:Class rdf:about="https://w3id.org/itsdata/location/v1/TpegPoint">
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/location/v1/TpegLoc"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/location/v1/hasPointCoordinates"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/itsdata/location/v1/PointCoordinates"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A point on the road network which is either a junction point or a non junction point.</rdfs:comment>
    </owl:Class>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/location/v1/both -->

    <owl:NamedIndividual rdf:about="https://w3id.org/itsdata/location/v1/both">
        <rdf:type rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirectionEnum"/>
        <rdf:type rdf:resource="https://w3id.org/itsdata/location/v1/LinearDirectionEnum"/>
        <rdfs:comment xml:lang="en">Indicates that both directions of traffic flow are affected by the situation or relate to the traffic data.</rdfs:comment>
    </owl:NamedIndividual>
    

    <!-- https://w3id.org/itsdata/location/v1/positive -->

    <owl:NamedIndividual rdf:about="https://w3id.org/itsdata/location/v1/positive">
        <rdf:type rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirectionEnum"/>
        <rdfs:comment xml:lang="en">The direction of navigation in an ALERT-C table that corresponds to the positive offset usage to go from the secondary location to the primary location within the ALERT-C location table.</rdfs:comment>
    </owl:NamedIndividual>
    

    <!-- https://w3id.org/itsdata/location/v1/negative -->

    <owl:NamedIndividual rdf:about="https://w3id.org/itsdata/location/v1/negative">
        <rdf:type rdf:resource="https://w3id.org/itsdata/location/v1/AlertCDirectionEnum"/>
        <rdfs:comment xml:lang="en">The direction of navigation in an ALERT-C table that corresponds to the negative offset usage to go from the secondary location to the primary location within the ALERT-C location table.</rdfs:comment>
    </owl:NamedIndividual>
    

</rdf:RDF>