BASE   <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX cdm1: <https://w3id.org/citydata/part1/>
PREFIX cdm2: <https://w3id.org/citydata/part2/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX terms: <http://purl.org/dc/terms/>
PREFIX its-core: <https://w3id.org/itsdata/core/>

:      a owl:Ontology;
    owl:versionIRI     :0.0.2;
    owl:imports    <http://www.w3.org/2002/07/owl>;
    owl:imports    <http://www.w3.org/2003/11/swrl>;
    owl:imports    <http://www.w3.org/2003/11/swrlb>;
    owl:imports    <http://www.w3.org/2006/time>;
    owl:imports    <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties>;
    owl:imports    <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology>;
    owl:imports    <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Code>;
    owl:imports    cdm1:;
    owl:imports    <https://www.opengis.net/ont/geosparql>;
    dc:title       "Ontology for ITS Location Referencing";
    terms:description  "This ontology defines concepts related to locations and positioning within the ITS domain using concepts specified in ISO/IEC 5087-1 and ISO/IEC-5087-2. The core ontology (OWL) defines the semantic model and is intended to remain stable. Validation constraints are defined in separate SHACL shape graphs. Changes to SHACL shapes are considered non-breaking to the semantic model unless otherwise stated. Applications SHOULD validate data against the recommended shapes for the given version.";
    its-core:draft     "true" .

:LocationObjectProperty a owl:ObjectProperty .

:areaLocation a owl:ObjectProperty;
    skos:definition     "Location defined by an area covering the surface (or near-surface) of the Earth"@en;
    rdfs:subPropertyOf  :LocationObjectProperty;
    rdfs:range          :AreaLocation .

:areasAtWhichApplicable a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:coordinatesForDisplay a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:destination a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty;
    rdfs:range          :Destination .

:directionPurpose a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:externalLocationReference a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty;
    owl:range           :ExternalLocationReferenceCode .

:geographicDescriptor a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:infrastructureDescriptor a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:lengthAffected a  owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:location a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:locationContainedInGroup a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:locationContainedInItinerary a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty;
    rdfs:domain     :ItineraryByIndexedLocations;
    rdfs:range      :IndexedLocation .

:locationPrecision a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:networkLocation a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:pointLocation a   owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:positionConfidence a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:positionOnCarriageway a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:positionalDescription a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

:routeDestination a owl:ObjectProperty;
    rdfs:subPropertyOf  :LocationObjectProperty .

cdm1:hasDescription a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

cdm1:hasIdentifier a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

cdm1:hasName a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

its-core:ITSDataProperty a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

:LocationDataProperty a owl:DatatypeProperty;
    rdfs:subPropertyOf  its-core:ITSDataProperty .

:elevation a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

:index a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

:latitude a  owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

:locationDescription a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

:longitude a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

</itsdata/time/v1/predefinedItineraryReference> a owl:DatatypeProperty;
    rdfs:subPropertyOf  </itsdata/time/v1/TimeDataProperty> .

</itsdata/time/v1/predefinedLocationGroupReference> a owl:DatatypeProperty;
    rdfs:subPropertyOf  </itsdata/time/v1/TimeDataProperty> .

:sequentialRampNumber a owl:DatatypeProperty;
    rdfs:subPropertyOf  :LocationDataProperty .

:AreaDestination a owl:Class;
    rdfs:subClassOf  :Destination.

:AreaLocation a owl:Class;
    rdfs:subClassOf  :Location.

:Destination a  owl:Class;
    rdfs:subClassOf  :LocationThing .

:DirectionCode a owl:Class;
    rdfs:subClassOf  :LocationThing;
    rdfs:subClassOf  cdm2:Code .

:IndexedLocation a owl:Class;
    rdfs:subClassOf  :LocationReference .

:Itinerary a owl:Class;
    rdfs:subClassOf  :LocationReference;
    skos:definition  "Multiple (i.e. more than one) physically separate locations arranged as an ordered set that defines an itinerary or route."@en .

:ItineraryByIndexedLocations a owl:Class;
    rdfs:subClassOf  :Itinerary .

:JurisdictionalEntity a owl:Class;
    rdfs:subClassOf  :LocationThing .

:LinearLocation a owl:Class;
    rdfs:subClassOf  :NetworkLocation .

:Location a  owl:Class;
    skos:definition  "The specification of a location either on a network (as a point or a linear location) or as an area. This may be provided in one or more referencing systems."@en;
    rdfs:subClassOf  :LocationReference .

:LocationGroup a owl:Class;
    rdfs:subClassOf  :LocationReference .

:LocationGroupByList a owl:Class;
    rdfs:subClassOf  :LocationGroup .

:LocationReference a owl:Class;
    skos:definition  "Represents one or more physically separate locations. Multiple locations may be related, as in an itinerary or route, or may be unrelated. One LocationReference should not use multiple Location objects to represent the same physical location."@en;
    rdfs:subClassOf  :LocationThing .

:LocationThing a owl:Class;
    rdfs:subClassOf  its-core:ITSThing .

:NetworkLocation a owl:Class;
    rdfs:subClassOf  :Location .

:Place a  owl:Class;
    rdfs:subClassOf  :LocationThing .

:PlaceTypeCode a owl:Class;
    rdfs:subClassOf  :LocationThing;
    rdfs:subClassOf  cdm2:Code .

:PointCoordinates a owl:Class;
    rdfs:subClassOf  :LocationThing .

:PointDestination a owl:Class;
    rdfs:subClassOf  :Destination .

:PointLocation a owl:Class;
    rdfs:subClassOf  :NetworkLocation .

:PositionConfidenceEllipse a owl:Class;
    rdfs:subClassOf  :LocationThing .

:SupplementaryPositionalDescription a owl:Class;
    rdfs:subClassOf  :LocationThing .
