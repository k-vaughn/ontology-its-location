###  https://w3id.org/itsdata/location/LocationObjectProperty
:LocationObjectProperty rdf:type owl:ObjectProperty .


###  https://w3id.org/itsdata/location/areaLocation
:areaLocation rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :LocationObjectProperty ;
              rdfs:range [ rdf:type owl:Restriction ;
                           owl:onProperty :areaLocation ;
                           owl:allValuesFrom :AreaLocation
                         ] ;
              terms:description "location defined by an area covering the surface (or near-surface) of the Earth" .


###  https://w3id.org/itsdata/location/areasAtWhichApplicable
:areasAtWhichApplicable rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :LocationObjectProperty .


