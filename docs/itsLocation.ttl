###  https://w3id.org/itsdata/location/AreaDestination
:AreaDestination rdf:type owl:Class ;
                 rdfs:subClassOf :Destination ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :areaLocation ;
                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :AreaLocation
                                 ] ;
                 xsd:pattern "LocationPattern" .


###  https://w3id.org/itsdata/location/AreaLocation
:AreaLocation rdf:type owl:Class ;
              rdfs:subClassOf :Location ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :areasAtWhichApplicable ;
                                owl:allValuesFrom cdm2:Code
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :areasAtWhichApplicable ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass cdm2:Code
                              ] ;
              xsd:pattern "LocationPattern" .


###  https://w3id.org/itsdata/location/Destination
:Destination rdf:type owl:Class ;
             rdfs:subClassOf :LocationThing ;
             xsd:pattern "LocationPattern" .


###  https://w3id.org/itsdata/location/IndexedLocation
:IndexedLocation rdf:type owl:Class ;
                 rdfs:subClassOf :LocationReference ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :location ;
                                   owl:allValuesFrom :Location
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :location ;
                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass :Location
