#################################################################
#    Rules
#################################################################

<https://isotc204.org/ontologies/its/location##indexedLoc1> rdf:type swrl:Variable .

<https://isotc204.org/ontologies/its/location##indexedLoc2> rdf:type swrl:Variable .

<https://isotc204.org/ontologies/its/location##itinerary> rdf:type swrl:Variable .

<https://isotc204.org/ontologies/its/location##indexVal> rdf:type swrl:Variable .

[ rdfs:comment "Enforces unique indices for IndexedLocations within an ItineraryByIndexedLocations (violation causes inconsistency)" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:DifferentIndividualsAtom ;
                           swrl:argument1 <https://isotc204.org/ontologies/its/location##indexedLoc1> ;
                           swrl:argument2 <https://isotc204.org/ontologies/its/location##indexedLoc2>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:ClassAtom ;
                                      swrl:classPredicate :ItineraryByIndexedLocations ;
                                      swrl:argument1 <https://isotc204.org/ontologies/its/location##itinerary>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                 swrl:propertyPredicate :locationContainedInItinerary ;
                                                 swrl:argument1 <https://isotc204.org/ontologies/its/location##itinerary> ;
                                                 swrl:argument2 <https://isotc204.org/ontologies/its/location##indexedLoc2>
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                            swrl:propertyPredicate :locationContainedInItinerary ;
                                                            swrl:argument1 <https://isotc204.org/ontologies/its/location##itinerary> ;
                                                            swrl:argument2 <https://isotc204.org/ontologies/its/location##indexedLoc1>
                                                          ] ;
                                                rdf:rest [ rdf:type swrl:AtomList ;
                                                           rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                                       swrl:propertyPredicate :index ;
                                                                       swrl:argument1 <https://isotc204.org/ontologies/its/location##indexedLoc1> ;
                                                                       swrl:argument2 <https://isotc204.org/ontologies/its/location##indexVal>
                                                                     ] ;
                                                           rdf:rest [ rdf:type swrl:AtomList ;
                                                                      rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                                                  swrl:propertyPredicate :index ;
                                                                                  swrl:argument1 <https://isotc204.org/ontologies/its/location##indexedLoc2> ;
                                                                                  swrl:argument2 <https://isotc204.org/ontologies/its/location##indexVal>
                                                                                ] ;
                                                                      rdf:rest rdf:nil
                                                                    ]
                                                         ]
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate owl:Nothing ;
                           swrl:argument1 <https://isotc204.org/ontologies/its/location##itinerary>
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

