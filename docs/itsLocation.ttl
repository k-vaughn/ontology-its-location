<https://w3id.org/itsdata/location/> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/itsdata/location/0.0.2> ;
                                      owl:imports <http://www.w3.org/2002/07/owl> ,
                                                  <http://www.w3.org/2003/11/swrl> ,
                                                  <http://www.w3.org/2003/11/swrlb> ,
