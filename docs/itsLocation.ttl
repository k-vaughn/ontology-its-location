                                                  cdm1: ,
                                                  <https://www.opengis.net/ont/geosparql> ;
                                      dc:title "Ontology for ITS Location Referencing" ;
                                      terms:description "This ontology defines concepts related to locations and positioning within the ITS domain using concepts specified in ISO/IEC 5087-1 and ISO/IEC-5087-2." .

