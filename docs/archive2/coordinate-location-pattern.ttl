@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <https://w3id.org/itsdata/location/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

:CoordinateLocationPattern
    a owl:Ontology ;
    dcterms:title "ITS Coordinate-based Location Referencing"@en ;
    skos:definition "Methodology module for locations referenced using coordinates and/or point geometry."@en ;
    dcterms:creator "Kenneth Vaughn" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    its-core:draft "true" ;
    owl:imports :LocationCorePattern ;
    owl:imports :LocationGeometryPattern ;
    owl:imports :LocationQualityPattern ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <https://w3id.org/itsdata/location/v1/CoordinateLocationPattern/r0.1> ;
    vann:preferredNamespacePrefix "its-location" ;
    vann:preferredNamespaceUri "https://w3id.org/itsdata/location/v1/" .

:CoordinateLocation
    a owl:Class ;
    rdfs:subClassOf :Location ;
    skos:definition "A location that is referenced using point coordinates and/or point geometry."@en .

:hasPointCoordinates
    a owl:ObjectProperty ;
    rdfs:domain :CoordinateLocation ;
    rdfs:range :PointCoordinates ;
    skos:definition "Associates a coordinate-based location with its point coordinate node."@en .

