BASE <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX cdm3: <https://w3id.org/citydata/part3/v1/>

:LinearReferencingSHACL
    a owl:Ontology ;
    dcterms:title "SHACL rules for ITS Linear Referencing (LRS) Location Referencing"@en ;
    skos:definition "SHACL shapes for linear referencing locations."@en ;
    its-core:draft "true" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <LinearReferencingSHACL/r0.1> .

:MeasureShape
    a sh:NodeShape ;
    sh:targetClass :Measure ;
    sh:property [
        sh:path :measureValue ;
        sh:node its-sh:ExactlyOneShape ;
        sh:datatype xsd:decimal ;
    ] .

:LinearLocationShape
    a sh:NodeShape ;
    sh:targetClass :LinearLocation ;
    sh:property [
        sh:path :referencedElement ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class cdm3:NetworkElement ;
    ] ;
    sh:property [
        sh:path :fromMeasure ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class :Measure ;
    ] ;
    sh:property [
        sh:path :toMeasure ;
        sh:node its-sh:MaxOneShape ;
        sh:class :Measure ;
    ] .

