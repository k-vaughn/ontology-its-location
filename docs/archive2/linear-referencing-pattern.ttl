@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <https://w3id.org/itsdata/location/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix cdm3: <https://w3id.org/citydata/part3/v1/> .

:LinearReferencingPattern
    a owl:Ontology ;
    dcterms:title "ITS Linear Referencing (LRS) Location Referencing"@en ;
    skos:definition "Methodology module for locations referenced along a transport network element using measures (linear referencing)."@en ;
    dcterms:creator "Kenneth Vaughn" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    its-core:draft "true" ;
    owl:imports :LocationCorePattern ;
    owl:imports :NetworkLocationPattern ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <https://w3id.org/itsdata/location/v1/LinearReferencingPattern/r0.1> ;
    vann:preferredNamespacePrefix "its-location" ;
    vann:preferredNamespaceUri "https://w3id.org/itsdata/location/v1/" .

:LinearLocation
    a owl:Class ;
    rdfs:subClassOf :NetworkLocation ;
    skos:definition "A location referenced along a network element using measure values."@en .

:Measure
    a owl:Class ;
    skos:definition "A measure along a linear element (units and referencing system may be specified by an LRS definition in future revisions)."@en .

:fromMeasure
    a owl:ObjectProperty ;
    rdfs:domain :LinearLocation ;
    rdfs:range :Measure ;
    skos:definition "Start measure of a linear location."@en .

:toMeasure
    a owl:ObjectProperty ;
    rdfs:domain :LinearLocation ;
    rdfs:range :Measure ;
    skos:definition "End measure of a linear location."@en .

:measureValue
    a owl:DatatypeProperty ;
    rdfs:domain :Measure ;
    rdfs:range xsd:decimal ;
    skos:definition "Numeric value of a measure."@en .

:referencedElement
    a owl:ObjectProperty ;
    rdfs:domain :LinearLocation ;
    rdfs:range cdm3:NetworkElement ;
    skos:definition "The linear element on which the measures are defined (typically a network link/segment)."@en .

