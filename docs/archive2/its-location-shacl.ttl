BASE <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:ItsLocationMethodsSHACL
    a owl:Ontology ;
    dcterms:title "ITS Location Referencing SHACL (methodology modules scaffold)"@en ;
    skos:definition "Master SHACL ontology that imports the methodology-first SHACL modules under docs/location-methods/. Existing SHACL in docs/ is not modified."@en ;
    its-core:draft "true" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <ItsLocationMethodsSHACL/r0.1> ;
    owl:imports :LocationCoreSHACL ;
    owl:imports :LocationGeometrySHACL ;
    owl:imports :LocationQualitySHACL ;
    owl:imports :CoordinateLocationSHACL ;
    owl:imports :AreaLocationSHACL ;
    owl:imports :NetworkLocationSHACL ;
    owl:imports :LinearReferencingSHACL ;
    owl:imports :OffsetLocationSHACL ;
    owl:imports :AddressLocationSHACL ;
    owl:imports :ExternalIdLocationSHACL ;
    owl:imports :AlertCAdapterSHACL ;
    owl:imports :OpenLRAdapterSHACL ;
    owl:imports :TPEGAdapterSHACL .

