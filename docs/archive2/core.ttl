@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <https://w3id.org/itsdata/location/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

:LocationCorePattern
    a owl:Ontology ;
    dcterms:title "ITS Location Referencing Core"@en ;
    skos:definition "Core abstractions for location references and collections used across multiple location-referencing methodologies."@en ;
    dcterms:creator "Kenneth Vaughn" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    its-core:draft "true" ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <https://w3id.org/itsdata/location/v1/LocationCorePattern/r0.1> ;
    vann:preferredNamespacePrefix "its-location" ;
    vann:preferredNamespaceUri "https://w3id.org/itsdata/location/v1/" .

### Core classes

:LocationReference
    a owl:Class ;
    skos:definition "A reference that denotes one or more physically separate locations."@en .

:Location
    a owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "A single location reference that may be represented using one or more equivalent methodologies (e.g., coordinates and an external identifier)."@en .

:LocationGroup
    a owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "An unordered set of multiple physically separate locations."@en .

:Itinerary
    a owl:Class ;
    rdfs:subClassOf :LocationReference ;
    skos:definition "An ordered set of multiple physically separate locations forming a route or itinerary."@en .

:IndexedLocation
    a owl:Class ;
    skos:definition "A location member with an explicit order index within an itinerary."@en .

### Core properties

:LocationObjectProperty
    a owl:ObjectProperty ;
    skos:definition "Organizational super-property for location core object properties."@en .

:LocationDataProperty
    a owl:DatatypeProperty ;
    skos:definition "Organizational super-property for location core data properties."@en .

:hasMember
    a owl:ObjectProperty ;
    rdfs:subPropertyOf :LocationObjectProperty ;
    rdfs:domain :LocationGroup ;
    rdfs:range :Location ;
    skos:definition "Relates a location group to a member location."@en .

:locationContainedInItinerary
    a owl:ObjectProperty ;
    rdfs:subPropertyOf :LocationObjectProperty ;
    rdfs:domain :Itinerary ;
    rdfs:range :IndexedLocation ;
    skos:definition "Relates an itinerary to an indexed location member."@en .

:hasLocation
    a owl:ObjectProperty ;
    rdfs:subPropertyOf :LocationObjectProperty ;
    rdfs:domain :IndexedLocation ;
    rdfs:range :Location ;
    skos:definition "Relates an indexed member to the referenced location."@en .

:index
    a owl:DatatypeProperty ;
    rdfs:subPropertyOf :LocationDataProperty ;
    rdfs:domain :IndexedLocation ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The order index of an indexed location member."@en .

:hasPrimaryRepresentation
    a owl:ObjectProperty ;
    rdfs:subPropertyOf :LocationObjectProperty ;
    rdfs:domain :Location ;
    rdfs:range owl:Thing ;
    skos:definition "Links a location to its preferred (primary) representation node."@en .

:hasAlternativeRepresentation
    a owl:ObjectProperty ;
    rdfs:subPropertyOf :LocationObjectProperty ;
    rdfs:domain :Location ;
    rdfs:range owl:Thing ;
    skos:definition "Links a location to an additional representation node intended to denote the same physical location."@en .

