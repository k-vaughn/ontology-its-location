BASE <https://w3id.org/itsdata/location/v1/>
PREFIX : <https://w3id.org/itsdata/location/v1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX cdm3: <https://w3id.org/citydata/part3/v1/>

:NetworkLocationSHACL
    a owl:Ontology ;
    dcterms:title "SHACL rules for ITS Network-anchored Location Referencing"@en ;
    skos:definition "SHACL shapes for network-anchored location referencing."@en ;
    its-core:draft "true" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-04-23"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <NetworkLocationSHACL/r0.1> .

:NetworkLocationShape
    a sh:NodeShape ;
    sh:targetClass :NetworkLocation ;
    sh:property [
        sh:path :hasNetworkElement ;
        sh:node its-sh:ExactlyOneShape ;
        sh:class cdm3:NetworkElement ;
    ] .

